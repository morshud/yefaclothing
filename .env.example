# Copy to .env for local development.
# In production, set these as Environment Variables (don't commit secrets).

# Database (PDO)

# SQLite example
# YEFA_DB_DSN="sqlite:storage/app.sqlite"

# MySQL example
# YEFA_DB_DSN="mysql:host=127.0.0.1;port=3306;dbname=yefaclothing;charset=utf8mb4"
# YEFA_DB_USER="your_db_user"
# YEFA_DB_PASS="your_db_password"

# Optional legacy admin creds (not required for DB-backed login)
# YEFA_ADMIN_EMAIL="admin@example.com"
# YEFA_ADMIN_PASSWORD_HASH="$2y$10$..."

# Troubleshooting (turn off in production once fixed)
# YEFA_APP_DEBUG=1
