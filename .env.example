# Copy to .env for local development.
# In production (e.g., Wasmer), set these as Environment Variables instead.

# Database (PDO)
# SQLite (local / simple)
YEFA_DB_DSN="sqlite:storage/app.sqlite"

# MySQL example
# YEFA_DB_DSN="mysql:host=127.0.0.1;dbname=yefaclothing;charset=utf8mb4"
# YEFA_DB_USER="root"
# YEFA_DB_PASS="password"

# Optional legacy admin creds (not required for DB-backed login)
# YEFA_ADMIN_EMAIL="admin@example.com"
# YEFA_ADMIN_PASSWORD_HASH="$2y$10$..."
