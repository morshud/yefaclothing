# Clean URLs: /login -> /login.php
# Also redirects /login.php -> /login
# Requires: AllowOverride All, mod_rewrite enabled.

RewriteEngine On

# 1) Canonical home URL.
#    /index.php -> /
RewriteCond %{REQUEST_METHOD} =GET [OR]
RewriteCond %{REQUEST_METHOD} =HEAD
RewriteCond %{THE_REQUEST} \s/+index\.php[\s?] [NC]
RewriteRule ^index\.php$ / [R=301,L]

#    /index -> /
RewriteCond %{REQUEST_METHOD} =GET [OR]
RewriteCond %{REQUEST_METHOD} =HEAD
RewriteRule ^index/?$ / [R=301,L]

# 2) Redirect direct .php requests to extensionless URLs (GET/HEAD only).
#    Example: /my-account.php -> /my-account
RewriteCond %{REQUEST_METHOD} =GET [OR]
RewriteCond %{REQUEST_METHOD} =HEAD
RewriteCond %{THE_REQUEST} \s/+(.+?)\.php[\s?] [NC]
RewriteRule ^ %1 [R=301,L]

# 3) If the requested path is an existing file or directory, serve it.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 4) Rewrite extensionless URLs to the corresponding .php file if it exists.
#    Example: /my-account -> /my-account.php
RewriteCond %{REQUEST_FILENAME}.php -f
RewriteRule ^(.+?)/?$ $1.php [L]
